{
	"name": "datepainter",
	"version": "1.0.0",
	"type": "module",
	"description": "A lightweight, flexible calendar component library with built-in date validation and state management. Works with Astro, Vanilla JS, and more.",
	"keywords": [
		"calendar",
		"date-picker",
		"validation",
		"astro",
		"vanilla",
		"typescript",
		"date",
		"rto",
		"return-to-office"
	],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/username/datepainter.git"
	},
	"homepage": "https://github.com/username/datepainter",
	"bugs": {
		"url": "https://github.com/username/datepainter/issues"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./stores": {
			"types": "./dist/stores/calendarStore.d.ts",
			"import": "./dist/stores/calendarStore.js"
		},
		"./styles/calendar.css": "./dist/styles/calendar.css",
		"./styles/base.css": "./dist/styles/base.css",
		"./styles/astro.css": "./dist/styles/astro.css",
		"./styles/vanilla.css": "./dist/styles/vanilla.css",
		"./styles/themes.css": "./dist/styles/themes.css",
		"./Calendar.astro": "./dist/components/Calendar.astro"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup && npm run copy:styles && npm run copy:stores",
		"copy:styles": "mkdir -p dist/styles && cp -r styles/* dist/styles/",
		"copy:stores": "mkdir -p dist/stores && cp -r src/stores/* dist/stores/ && sed -i 's|from \"../types\"|from \"datepainter\"|g' dist/stores/*.ts",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"date-fns": "^4.1.0",
		"nanostores": "1.1.0"
	},
	"peerDependencies": {
		"astro": "^4.16.12 || ^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@vitest/ui": "2.1.8",
		"tsup": "^8.0.0",
		"typescript": "5.7.2",
		"vitest": "2.1.8"
	}
}
