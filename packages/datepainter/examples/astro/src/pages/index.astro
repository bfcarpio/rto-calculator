---
// No server-side setup needed - CalendarManager runs client-side
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Datepainter - Astro Example</title>
  <style>
    import 'datepainter/styles/base.css';
    import 'datepainter/styles/astro.css';
  </style>
</head>
<body>
  <main>
    <h1>Datepainter - Astro Example</h1>
    <p>Use <strong>ArrowLeft</strong> and <strong>ArrowRight</strong> keys to navigate months. 
       Click on dates to select them. Click again to cycle through states (Working → OOF → Holiday).</p>

    <div id="calendar-container"></div>

    <div class="info">
      <h2>Selected Dates</h2>
      <div id="selected-dates">No dates selected</div>
    </div>
  </main>

  <script>
    import { CalendarManager } from 'datepainter';

    // Initialize calendar with config
    const manager = new CalendarManager('#calendar-container', {
      dateRange: {
        start: new Date('2026-01-01'),
        end: new Date('2026-12-31')
      },
      states: {
        working: {
          label: 'Working',
          color: '#10b981',
          bgColor: '#d1fae5',
          icon: '💼'
        },
        oof: {
          label: 'OOF',
          color: '#ef4444',
          bgColor: '#fee2e2',
          icon: '🏠'
        },
        holiday: {
          label: 'Holiday',
          color: '#f59e0b',
          bgColor: '#fef3c7',
          icon: '🏖️'
        }
      },
      styling: {
        showWeekdays: true,
        showWeekNumbers: true,
        firstDayOfWeek: 1
      },
      painting: {
        enabled: true,
        paintOnDrag: true,
        defaultState: 'oof'
      }
    });

    // Initialize the calendar
    manager.init();

    // Navigation controls
    const navContainer = document.createElement('div');
    navContainer.className = 'nav-controls';
    navContainer.style.cssText = 'margin-bottom: 1rem; display: flex; gap: 1rem;';

    const prevBtn = document.createElement('button');
    prevBtn.textContent = '← Previous Month';
    prevBtn.onclick = () => {
      try {
        manager.prevMonth();
      } catch (error) {
        const errorMessage = error instanceof Error ? error.message : String(error);
        console.log('Already at start of date range:', errorMessage);
      }
    };

    const nextBtn = document.createElement('button');
    nextBtn.textContent = 'Next Month →';
    nextBtn.onclick = () => {
      try {
        manager.nextMonth();
      } catch (error) {
        const errorMessage = error instanceof Error ? error.message : String(error);
        console.log('Already at end of date range:', errorMessage);
      }
    };

    navContainer.appendChild(prevBtn);
    navContainer.appendChild(nextBtn);

    // Insert before info section
    const infoSection = document.querySelector('.info');
    if (infoSection && infoSection.parentNode) {
      infoSection.parentNode.insertBefore(navContainer, infoSection);
    }

    // State colors for display
    const stateColors = {
      working: '#10b981',
      oof: '#ef4444',
      holiday: '#f59e0b'
    };

    function updateSelectedDatesDisplay() {
      const container = document.getElementById('selected-dates');
      if (!container) return;

      const dates = manager.getSelectedDates();
      const dateMap = new Map();

      // Get state for each date
      dates.forEach(date => {
        const state = manager.getState(date);
        if (state) {
          dateMap.set(date, state);
        }
      });

      if (dateMap.size === 0) {
        container.textContent = 'No dates selected';
        return;
      }

      const sortedDates = Array.from(dateMap.entries()).sort((a, b) => a[0].localeCompare(b[0]));

      container.innerHTML = sortedDates.map(([date, state]) => {
        const actualColor = (state === 'working' && stateColors.working) ||
                          (state === 'oof' && stateColors.oof) ||
                          (state === 'holiday' && stateColors.holiday) ||
                          '#6b7280';
        return `<span class="date-chip" style="
          background-color: ${actualColor};
          color: white;
          padding: 4px 8px;
          border-radius: 4px;
          margin: 2px;
          display: inline-block;
        ">
          ${date} (${state})
        </span>`;
      }).join('');
    }

    // Subscribe to state changes
    manager.onStateChange(() => {
      updateSelectedDatesDisplay();
    });

    // Initial display update
    updateSelectedDatesDisplay();
  </script>
</body>
</html>

<style>
  :root {
    --bg-color: #ffffff;
    --text-color: #1f2937;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg-color);
    color: var(--text-color);
    margin: 0;
    padding: 2rem;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  p {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  #calendar-container {
    margin-bottom: 2rem;
  }

  .info {
    background: #f9fafb;
    padding: 1.5rem;
    border-radius: 8px;
  }

  .info h2 {
    margin-top: 0;
    font-size: 1.25rem;
  }

  #selected-dates {
    min-height: 40px;
  }
</style>
