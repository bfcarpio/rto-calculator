---
interface ButtonConfig {
	id: string;
	text: string;
	icon: string;
	variant: "primary" | "secondary" | "danger";
	ariaLabel: string;
}

const { position } = Astro.props;

// Button configurations
const _buttons: ButtonConfig[] = [
	{
		id: `undo-button-${position}`,
		text: "Undo",
		icon: "↩",
		variant: "secondary",
		ariaLabel: "Undo last action",
	},
	{
		id: `redo-button-${position}`,
		text: "Redo",
		icon: "↪",
		variant: "secondary",
		ariaLabel: "Redo last undone action",
	},
	{
		id: `clear-month-button-${position}`,
		text: "Clear Month",
		icon: "🧹",
		variant: "secondary",
		ariaLabel: "Clear selections in current month",
	},
	{
		id: `clear-all-button-${position}`,
		text: "Clear All",
		icon: "🗑️",
		variant: "danger",
		ariaLabel: "Clear all selections",
	},
];
---

<div class="action-buttons" data-position={position}>
    {_buttons.map((button) => (
        <button
            id={button.id}
            class={`button button-${button.variant}`}
            type="button"
            aria-label={button.ariaLabel}
            data-button-type={button.variant}
            disabled={button.id.includes("undo-button") || button.id.includes("redo-button") || undefined}
            data-testid={button.id.includes("undo-button")
                ? "undo-button"
                : button.id.includes("redo-button")
                ? "redo-button"
                : button.id.includes("clear-month")
                ? "clear-month-button"
                : button.id.includes("clear-all")
                ? "clear-all-button"
                : undefined}
        >
            <span class="button-icon" aria-hidden="true">{button.icon}</span>
            <span class="button-text">{button.text}</span>
        </button>
    ))}
</div>

<style>
    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        align-items: center;
        padding: 1rem 0;
        flex-wrap: wrap;
    }

    .action-buttons[data-position="top"] {
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #e8e8e8;
        margin-bottom: 1rem;
    }

    .action-buttons[data-position="bottom"] {
        padding-top: 1.5rem;
        border-top: 2px solid #e8e8e8;
        margin-top: 1rem;
    }

    .button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 4px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        min-height: 40px;
    }

    .button:focus {
        outline: 2px solid #1890ff;
        outline-offset: 2px;
    }

    .button:focus:not(:focus-visible) {
        outline: none;
    }

    .button:focus-visible {
        outline: 2px solid #1890ff;
        outline-offset: 2px;
    }

    .button:active {
        transform: scale(0.95);
    }

    .button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .button-primary {
        background-color: #1890ff;
        color: white;
    }

    .button-primary:hover:not(:disabled) {
        background-color: #40a9ff;
        transform: scale(1.05);
    }

    .button-primary:active:not(:disabled) {
        background-color: #096dd9;
        transform: scale(0.95);
    }

    .button-secondary {
        background-color: #f0f0f0;
        color: #333;
        border: 1px solid #d9d9d9;
    }

    .button-secondary:hover:not(:disabled) {
        background-color: #fafafa;
        border-color: #40a9ff;
        transform: scale(1.05);
    }

    .button-secondary:active:not(:disabled) {
        background-color: #e6e6e6;
        border-color: #096dd9;
        transform: scale(0.95);
    }

    .button-danger {
        background-color: #ff4d4f;
        color: white;
    }

    .button-danger:hover:not(:disabled) {
        background-color: #ff7875;
        transform: scale(1.05);
    }

    .button-danger:active:not(:disabled) {
        background-color: #d9363e;
        transform: scale(0.95);
    }

    .button-icon {
        font-size: 1.1rem;
        line-height: 1;
    }

    .button-text {
        line-height: 1;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .action-buttons {
            gap: 0.5rem;
        }

        .button {
            padding: 0.4rem 0.8rem;
            font-size: 0.9rem;
            min-height: 36px;
        }
    }

    @media (max-width: 480px) {
        .action-buttons {
            flex-direction: column;
            width: 100%;
        }

        .button {
            width: 100%;
            justify-content: center;
        }
    }

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
        .button,
        .button:hover,
        .button:active {
            transition: none;
            transform: none;
        }
    }

    /* High contrast mode support */
    @media (prefers-contrast: high) {
        .button {
            border: 2px solid currentColor;
        }
    }

</style>

<script>
  import type { CalendarInstance, DateString } from 'datepainter';

  function getCalendarManager(): CalendarInstance | null {
    return (window as any).__datepainterInstance || null;
  }

  /** Clear date selections in the current month only */
  function handleClearMonth(): void {
    const calendarManager = getCalendarManager();
    if (!calendarManager) return;

    const current = calendarManager.getCurrentMonth();
    const after = new Date(current.getFullYear(), current.getMonth(), 0); // last day of prev month
    const before = new Date(current.getFullYear(), current.getMonth() + 1, 1); // first day of next month

    const ranges = calendarManager.getDateRanges({ after, before });
    const datesToClear = ranges.flatMap(({ start, end }) => {
      const dates: DateString[] = [];
      const d = new Date(start);
      while (d <= end) {
        dates.push(d.toISOString().slice(0, 10) as DateString);
        d.setDate(d.getDate() + 1);
      }
      return dates;
    });

    if (datesToClear.length > 0) {
      calendarManager.clearDates(datesToClear);
    }
  }

  /** Clear all date selections */
  function handleClearAll(): void {
    const calendarManager = getCalendarManager();
    if (!calendarManager) return;

    if (!confirm('Clear all marked dates?')) return;

    calendarManager.clearAll();
  }

  import type { KeyboardShortcuts } from '../scripts/keyboard-shortcuts';

  function getKeyboardShortcuts(): KeyboardShortcuts | null {
    return (window as any).__keyboardShortcutsInstance ?? null;
  }

  function handleUndo(): void {
    getKeyboardShortcuts()?.handleUndo();
  }

  function handleRedo(): void {
    getKeyboardShortcuts()?.handleRedo();
  }

  // Wire up buttons
  document.querySelectorAll('[data-testid="undo-button"]').forEach((btn) => {
    btn.addEventListener('click', handleUndo);
  });
  document.querySelectorAll('[data-testid="redo-button"]').forEach((btn) => {
    btn.addEventListener('click', handleRedo);
  });
  document.querySelectorAll('[data-testid="clear-month-button"]').forEach((btn) => {
    btn.addEventListener('click', handleClearMonth);
  });
  document.querySelectorAll('[data-testid="clear-all-button"]').forEach((btn) => {
    btn.addEventListener('click', handleClearAll);
  });

  // Listen for history-changed to toggle undo/redo disabled state
  window.addEventListener('history-changed', ((e: CustomEvent<{ canUndo: boolean; canRedo: boolean }>) => {
    const { canUndo, canRedo } = e.detail;
    document.querySelectorAll('[data-testid="undo-button"]').forEach((btn) => {
      (btn as HTMLButtonElement).disabled = !canUndo;
    });
    document.querySelectorAll('[data-testid="redo-button"]').forEach((btn) => {
      (btn as HTMLButtonElement).disabled = !canRedo;
    });
  }) as EventListener);
</script>
