---
/**
 * WindowRow — single window summary row for WindowExplorer and WindowBreakdown.
 *
 * Produces identical HTML to buildWindowRowHtml (from ../lib/ui/windowRow),
 * but as a server-rendered Astro component. Both consumers render the same
 * we-row structure for the same WindowSummary data.
 *
 * Styling comes from window-shared.css — no <style> block here.
 */

import { buildDotHtml } from "../lib/ui/weekDot";
import { buildWindowRangeLabel } from "../lib/ui/windowRange";
import type { WindowSummary } from "../lib/validation/all-windows";

interface Props {
	summary: WindowSummary;
}

const { summary } = Astro.props;

const label = buildWindowRangeLabel(summary.weekDetails);
const tagClass = summary.isValid ? "we-row-tag--pass" : "we-row-tag--fail";
const tagText = summary.isValid ? "PASS" : "FAIL";
const dots = summary.weekDetails.map(buildDotHtml).join("");
---

<div class="we-row">
  <span class="we-row-label">{label}</span>
  <span class={`we-row-tag ${tagClass}`}>{tagText}</span>
  <span class="we-row-dots"><Fragment set:html={dots} /></span>
  <span class="we-row-avg">{summary.averageOfficeDays.toFixed(1)}</span>
</div>