---
import "../styles/window-shared.css";
/**
 * WindowBreakdown.astro - Displays visual breakdown of compliance window weeks
 *
 * Renders a single window row using the same buildWindowRowHtml function
 * as WindowExplorer, ensuring identical HTML structure and CSS classes.
 */

import { buildWindowRowHtml } from "../lib/ui/windowRow";
import type { WindowSummary } from "../lib/validation/all-windows";

export interface WindowBreakdownProps {
	/** The selected window summary (same object Explorer uses) */
	selectedSummary?: WindowSummary;
}

const { selectedSummary } = Astro.props as unknown as WindowBreakdownProps;

// Early exit: no data to display
const hasData = selectedSummary && selectedSummary.weekDetails.length > 0;
---

<div class="window-breakdown-wrapper">
	<div class="content" id="window-breakdown-content">
		{hasData ? (
			<Fragment set:html={buildWindowRowHtml(selectedSummary)} />
		) : (
			<p class="has-text-centered has-text-grey-light is-size-7">
				Mark dates to see window breakdown
			</p>
		)}
	</div>
</div>

<style>
	.window-breakdown-wrapper {
		width: 100%;
	}
</style>
