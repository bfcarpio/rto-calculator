---
---

<details class="holiday-drawer" id="holiday-drawer">
  <summary class="holiday-drawer__summary">
    <span class="holiday-drawer__title">Public Holidays</span>
    <span class="holiday-drawer__chevron" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.646 6.646a.5.5 0 0 1 .708 0L8 9.293l2.646-2.647a.5.5 0 0 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-3-3a.5.5 0 0 1 0-.708z" />
      </svg>
    </span>
  </summary>
  <div class="holiday-drawer__content">
    <p class="holiday-drawer__description">
      Select a country to automatically mark public holidays on the calendar.
    </p>
    <select id="country-select" class="holiday-drawer__select">
      <option value="">Select a country...</option>
    </select>
    <select id="company-select" class="holiday-drawer__select holiday-drawer__select--company" style="display: none;">
      <option value="">All public holidays</option>
    </select>
    <div id="holiday-status" class="holiday-drawer__status"></div>
  </div>
</details>

<style>
  .holiday-drawer {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .holiday-drawer__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: #f8fafc;
    transition: background-color 0.2s ease;
  }

  .holiday-drawer__summary::-webkit-details-marker {
    display: none;
  }

  .holiday-drawer__summary::marker {
    display: none;
  }

  .holiday-drawer__summary:hover {
    background: #f1f5f9;
  }

  .holiday-drawer__summary:focus-visible {
    outline: 2px solid #485fc7;
    outline-offset: -2px;
  }

  .holiday-drawer[open] .holiday-drawer__summary {
    border-bottom: 1px solid #e2e8f0;
  }

  .holiday-drawer__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: #334155;
  }

  .holiday-drawer__chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    color: #64748b;
  }

  .holiday-drawer[open] .holiday-drawer__chevron {
    transform: rotate(180deg);
  }

  .holiday-drawer__content {
    padding: 0.75rem 1rem;
  }

  .holiday-drawer__description {
    margin: 0 0 0.5rem 0;
    font-size: 0.8rem;
    color: #64748b;
    line-height: 1.4;
  }

  .holiday-drawer__select {
    width: 100%;
    padding: 0.5rem;
    border: 2px solid #e2e8f0;
    border-radius: 6px;
    font-size: 0.875rem;
    background: white;
    appearance: auto;
    -webkit-appearance: menulist;
    -moz-appearance: menulist;
    min-height: 40px;
    cursor: pointer;
  }

  .holiday-drawer__select--company {
    margin-top: 0.5rem;
  }

  .holiday-drawer__select:disabled {
    background: #f1f5f9;
    color: #94a3b8;
    cursor: not-allowed;
  }

  .holiday-drawer__status {
    font-size: 0.8rem;
    margin-top: 0.5rem;
    min-height: 1.2em;
  }

  .holiday-drawer__status--loading {
    color: #475569;
  }

  .holiday-drawer__status--success {
    color: #059669;
  }

  .holiday-drawer__status--error {
    color: #dc2626;
  }

  /* Dark mode */
  body.dark-mode .holiday-drawer {
    border-color: #334155;
  }

  body.dark-mode .holiday-drawer__summary {
    background: #1e293b;
  }

  body.dark-mode .holiday-drawer__summary:hover {
    background: #334155;
  }

  body.dark-mode .holiday-drawer[open] .holiday-drawer__summary {
    border-bottom-color: #334155;
  }

  body.dark-mode .holiday-drawer__title {
    color: #e2e8f0;
  }

  body.dark-mode .holiday-drawer__chevron {
    color: #94a3b8;
  }

  body.dark-mode .holiday-drawer__description {
    color: #94a3b8;
  }

  body.dark-mode .holiday-drawer__select {
    background: #1e293b;
    border-color: #334155;
    color: #e2e8f0;
  }

  body.dark-mode .holiday-drawer__select:disabled {
    background: #334155;
    color: #64748b;
  }
</style>

<script>
  import type { CalendarInstance, DateString } from 'datepainter';
  import { COUNTRIES } from '../lib/holiday/data/countries';
  import { getHolidayManager } from '../lib/holiday/HolidayManager';
  import { getDateRange, formatDateISO } from '../lib/dateUtils';

  const autoAddedHolidays = new Set<DateString>();

  const countrySelect = document.getElementById('country-select') as HTMLSelectElement;
  const companySelect = document.getElementById('company-select') as HTMLSelectElement;
  const statusDiv = document.getElementById('holiday-status') as HTMLElement;

  // Populate dropdown from shared COUNTRIES list
  for (const country of COUNTRIES) {
    const option = document.createElement('option');
    option.value = country.code;
    option.textContent = `${country.flag} ${country.name}`;
    countrySelect.appendChild(option);
  }

  function setStatus(text: string, type?: 'loading' | 'success' | 'error'): void {
    statusDiv.textContent = text;
    statusDiv.className = 'holiday-drawer__status';
    if (type) {
      statusDiv.classList.add(`holiday-drawer__status--${type}`);
    }
  }

  function populateCompanySelect(companies: string[]): void {
    // Remove all options except the first "All public holidays"
    while (companySelect.options.length > 1) {
      companySelect.remove(1);
    }
    for (const name of companies) {
      const option = document.createElement('option');
      option.value = name;
      option.textContent = name;
      companySelect.appendChild(option);
    }
    companySelect.value = '';
    companySelect.style.display = '';
  }

  function hideCompanySelect(): void {
    companySelect.style.display = 'none';
    companySelect.value = '';
  }

  async function fetchAndApplyHolidays(countryCode: string, companyName: string): Promise<void> {
    const calendarManager = (window as any).__datepainterInstance as CalendarInstance | null;
    if (!calendarManager) {
      setStatus('Calendar not ready. Please try again.', 'error');
      return;
    }

    // Clear previous auto-added holidays (only those still in 'holiday' state)
    const toRemove: DateString[] = [];
    for (const date of autoAddedHolidays) {
      if (calendarManager.getState(date) === 'holiday') {
        toRemove.push(date);
      }
    }
    if (toRemove.length > 0) {
      calendarManager.clearDates(toRemove);
    }
    autoAddedHolidays.clear();

    if (!countryCode) {
      setStatus('');
      return;
    }

    setStatus('Fetching holidays...', 'loading');
    countrySelect.disabled = true;
    companySelect.disabled = true;

    try {
      const range = getDateRange();
      const startYear = range.startDate.getFullYear();
      const endYear = range.endDate.getFullYear();
      const years: number[] = [];
      for (let y = startYear; y <= endYear; y++) {
        years.push(y);
      }

      const rangeStart = formatDateISO(range.startDate);
      const rangeEnd = formatDateISO(range.endDate);

      const manager = await getHolidayManager();
      const fetchOptions: { countryCode: string; years: number[]; companyName?: string } = { countryCode, years };
      if (companyName) {
        fetchOptions.companyName = companyName;
      }
      const result = await manager.fetchHolidays(fetchOptions);

      const datesToAdd: DateString[] = [];
      for (const holiday of result.holidays) {
        const dateStr = formatDateISO(holiday.date) as DateString;
        if (dateStr < rangeStart || dateStr > rangeEnd) continue;
        if (calendarManager.getState(dateStr) === 'holiday') continue;
        datesToAdd.push(dateStr);
      }

      if (datesToAdd.length > 0) {
        calendarManager.setDates(datesToAdd, 'holiday');
      }
      for (const d of datesToAdd) {
        autoAddedHolidays.add(d);
      }

      const count = datesToAdd.length;
      setStatus(
        count > 0
          ? `Added ${count} holiday${count !== 1 ? 's' : ''}.`
          : 'All holidays already marked.',
        'success'
      );
    } catch (error) {
      console.error('[HolidayCountrySelector] Failed to fetch holidays:', error);
      setStatus('Failed to fetch holidays. Please try again.', 'error');
    } finally {
      countrySelect.disabled = false;
      companySelect.disabled = false;
    }
  }

  async function handleCountryChange(countryCode: string): Promise<void> {
    if (!countryCode) {
      hideCompanySelect();
      await fetchAndApplyHolidays('', '');
      return;
    }

    const manager = await getHolidayManager();
    const companies = manager.getAvailableCompanies(countryCode);
    if (companies.length > 0) {
      populateCompanySelect(companies);
    } else {
      hideCompanySelect();
    }

    await fetchAndApplyHolidays(countryCode, '');
  }

  countrySelect.addEventListener('change', () => {
    handleCountryChange(countrySelect.value);
  });

  companySelect.addEventListener('change', () => {
    const countryCode = countrySelect.value;
    if (countryCode) {
      fetchAndApplyHolidays(countryCode, companySelect.value);
    }
  });
</script>
