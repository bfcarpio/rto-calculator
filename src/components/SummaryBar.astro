---
// SummaryBar.astro - Display compliance metrics
// Reactive client-side component that reads from datepainter API

import SettingIndicator from "./SettingIndicator.astro";
---
// SummaryBar.astro - Display compliance metrics
// Reactive client-side component that reads from datepainter API
---

<section class="hero is-light summary-bar" aria-labelledby="summary-heading">
	<div class="hero-body">
		<div class="columns is-mobile is-vcentered">
			<!-- Left Column: Compliance Status -->
			<div class="column">
			<h2 id="summary-heading" class="title is-5 mb-2">
				Average <span id="summary-average-label">In-Office</span>: <span id="summary-average" class="has-text-weight-bold has-text-primary">0</span>/<SettingIndicator settingKey="totalWeekdaysPerWeek" /> days
			</h2>
					Average <span id="summary-average-label">In-Office</span>: <span id="summary-average" class="has-text-weight-bold has-text-primary">0</span>/5 days
				</h2>
				<p class="subtitle is-7 mb-0">
					Based on your tracked attendance
				</p>
			</div>

			<!-- Right Column: Day Count Tags -->
			<div class="column is-narrow">
				<div class="tags has-addons is-flex-direction-column is-align-items-flex-end">
					<div class="tag is-info is-light mb-2">
						<span class="has-text-weight-semibold">Working:</span>&nbsp;<span id="summary-working">0</span> days
					</div>
					<div class="tag is-warning is-light mb-2">
						<span class="has-text-weight-semibold">WFH:</span>&nbsp;<span id="summary-oof">0</span> days
					</div>
					<div class="tag is-light">
						<span class="has-text-weight-semibold">Holiday:</span>&nbsp;<span id="summary-holiday">0</span> days
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.summary-bar {
		border-radius: 6px;
		margin-bottom: 1.5rem;
	}

	.summary-bar .hero-body {
		padding: 1.5rem;
	}

	/* Mobile adjustments */
	@media (max-width: 768px) {
		.summary-bar .hero-body {
			padding: 1rem;
		}

		.summary-bar .columns {
			flex-direction: column;
		}

		.summary-bar .column.is-narrow {
			margin-top: 1rem;
			align-items: flex-start !important;
		}

		.tags.is-flex-direction-column {
			flex-direction: row !important;
			flex-wrap: wrap;
		}

		.tags.is-flex-direction-column .tag {
			margin-right: 0.5rem;
			margin-bottom: 0.5rem;
		}
	}
</style>

<script>
	import { onComplianceUpdated, getLatestCompliance, type ComplianceEventData } from '../lib/auto-compliance';

	function updateSummary(data: ComplianceEventData): void {
		const elAvg = document.getElementById('summary-average');
		const elWorking = document.getElementById('summary-working');
		const elOof = document.getElementById('summary-oof');
		const elHoliday = document.getElementById('summary-holiday');

		if (elAvg) {
			const shouldRound = data.roundPercentage !== false;
			elAvg.textContent = shouldRound 
				? Math.round(data.averageOfficeDays).toString() 
				: data.averageOfficeDays.toFixed(1);
		}
		const elAvgLabel = document.getElementById('summary-average-label');
		if (elAvgLabel) {
			elAvgLabel.textContent = data.roundPercentage !== false ? 'In-Office (rounded)' : 'In-Office';
		}
		if (elWorking) elWorking.textContent = String(data.totalWorkingDays);
		if (elOof) elOof.textContent = String(data.totalWfhDays);
		if (elHoliday) elHoliday.textContent = String(data.totalHolidayDays);
	}

	// Subscribe to auto-compliance events
	onComplianceUpdated(updateSummary);

	// If auto-compliance already ran before we loaded, use cached result
	const cached = getLatestCompliance();
	if (cached) updateSummary(cached);
</script>
