---
import { validationManager } from "../scripts/ValidationManager";
import type { ValidationConfig } from "../types/validation-strategy";

export type SettingKey = keyof ValidationConfig;

interface Props {
	settingKey: SettingKey;
	label?: string;
}

const { settingKey, label } = Astro.props as unknown as Props;

const initialConfig = validationManager?.getConfig?.() ?? {};
const initialValue = (initialConfig as ValidationConfig)[settingKey];

const uid = Math.random().toString(36).slice(2, 8);
const valueElId = `setting-indicator-value-${settingKey}-${uid}`;
const wrapperId = `setting-indicator-wrapper-${settingKey}-${uid}`;
const tooltipId = `setting-indicator-tooltip-${settingKey}-${uid}`;
---

<span
	id={wrapperId}
	class="setting-indicator"
	data-setting-key={settingKey}
	aria-describedby={tooltipId}
	title={initialValue !== undefined ? `Setting: ${settingKey} = ${initialValue}` : `Setting: ${settingKey} value`}
>
	{label ? (
		<span class="control">
			<span class="tag is-light" aria-label={label}>{label}</span>
		</span>
	) : null}
	<span class="control">
		<span
			id={valueElId}
			class="has-text-weight-semibold setting-value"
			data-setting-key={settingKey}
		>
			{initialValue}
		</span>
	</span>
	<span id={tooltipId} class="sr-only">{`Setting: ${settingKey} = ${initialValue}`}</span>
</span>

<script>
	(function(){
		// Handler for unified event
		function handleStateChange(ev: Event) {
			const detail = (ev as CustomEvent).detail;
			if (!detail || detail.type !== 'config' || !detail.settingKey) return;

			// Query all matching elements each time (handles dynamically created elements)
			const matchingWrappers = document.querySelectorAll(`.setting-indicator[data-setting-key="${detail.settingKey}"]`);
			
			matchingWrappers.forEach(wrapper => {
				const valueEl = wrapper.querySelector(".setting-value");
				const tooltipEl = wrapper.querySelector(".sr-only");

				if (!valueEl) return;

				const newValue = detail.newValue;
				valueEl.textContent = String(newValue);
				wrapper.setAttribute("title", `Setting: ${detail.settingKey} = ${newValue}`);
				if (tooltipEl) tooltipEl.textContent = `Setting: ${detail.settingKey} = ${newValue}`;
			});
		}

		// Listen to unified event
		window.addEventListener("rto:state-changed", handleStateChange);
	})();
</script>

<style>
	.setting-indicator {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	.setting-value {
		text-decoration: underline dotted;
		text-underline-offset: 2px;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
