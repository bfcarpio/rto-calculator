---
import SettingIndicator from "./SettingIndicator.astro";

export interface Props {
	isCompliant?: boolean;
	roundPercentage?: boolean;
	bestWeekCount?: number;
}

const {
	isCompliant = false,
	roundPercentage = false,
	bestWeekCount = 8,
} = Astro.props;
---

<p class="has-text-centered has-text-weight-semibold" id="compliance-status-message" role="status" aria-live="polite">
	<span id="compliance-label">
		<strong class="status-text">{isCompliant ? "Compliant:" : "Not compliant:"}</strong>
		Best
		<span class="setting-indicator" data-setting-key="bestWeeksCount">
			<span class="setting-value" data-setting-key="bestWeeksCount">{bestWeekCount}</span>
		</span>
		of
		<SettingIndicator settingKey="rollingPeriodWeeks" />
		weeks average<span class="rounded-indicator">{roundPercentage ? " (rounded)" : ""}</span>
		<span class="avg-days"></span>
		office days.
		Required:
		<SettingIndicator settingKey="minOfficeDaysPerWeek" />
	</span>
</p>

<script>
	import { onComplianceChange } from "../lib/stores/complianceStore";

	const labelEl = document.getElementById("compliance-label");

	function updateLabel(data: {
		isCompliant: boolean;
		roundPercentage: boolean;
		averageOfficeDays: number;
		bestWeekCount: number;
		requiredDays: number;
		totalWeeks: number;
	}): void {
		if (!labelEl) return;

		// Update status text
		const statusText = labelEl.querySelector(".status-text");
		if (statusText) {
			statusText.textContent = data.isCompliant ? "Compliant:" : "Not compliant:";
		}

		// Update rounded indicator
		const roundedIndicator = labelEl.querySelector(".rounded-indicator");
		if (roundedIndicator) {
			roundedIndicator.textContent = data.roundPercentage ? " (rounded)" : "";
		}

		// Update average days
		const avgDays = labelEl.querySelector(".avg-days");
		if (avgDays) {
			avgDays.textContent = data.roundPercentage
				? ` ${Math.round(data.averageOfficeDays)}`
				: ` ${data.averageOfficeDays.toFixed(1)}`;
		}

		// Update setting indicators from compliance data
		// These must stay in sync with policy settings so the label
		// always reflects the current minOfficeDaysPerWeek and rollingPeriodWeeks.
		const bestWeeksValue = labelEl.querySelector(
			'.setting-value[data-setting-key="bestWeeksCount"]',
		);
		if (bestWeeksValue) {
			bestWeeksValue.textContent = String(data.bestWeekCount);
		}

		const requiredDaysValue = labelEl.querySelector(
			'.setting-value[data-setting-key="minOfficeDaysPerWeek"]',
		);
		if (requiredDaysValue) {
			requiredDaysValue.textContent = String(data.requiredDays);
		}

		const totalWeeksValue = labelEl.querySelector(
			'.setting-value[data-setting-key="rollingPeriodWeeks"]',
		);
		if (totalWeeksValue) {
			totalWeeksValue.textContent = String(data.totalWeeks);
		}
	}

	// Page-lifetime subscription — no cleanup needed for static Astro pages
	// onComplianceChange fires immediately if store has data, so no separate get() needed
	onComplianceChange(updateLabel);
</script>

<style>
	.setting-indicator {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	.setting-value {
		text-decoration: underline dotted;
		text-underline-offset: 2px;
	}
</style>
